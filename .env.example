# ============================================================
# Copia este fichero como .env y rellena tus valores.
# Nunca subas .env al repositorio (ya esta en .gitignore).
# En AWS los valores se inyectan via ECS Task Definition o
# Parameter Store; este fichero solo se usa en local/dev.
# ============================================================

# ---- Tradovate (credenciales) -------------------------------
# Entorno de Tradovate: "demo" para paper trading, "live" para real
TRADOVATE_ENV=demo
# Credenciales de tu cuenta Tradovate
TRADOVATE_USERNAME=tu_email@ejemplo.com
TRADOVATE_PASSWORD=tu_contrasena
# API add-on: CID y Secret de tu aplicacion en el portal de Tradovate
TRADOVATE_CID=tu_cid
TRADOVATE_SECRET=tu_secret
# Opcionales (el bot usa estos valores por defecto si no se definen)
# TRADOVATE_APP_ID=MyTradingBot
# TRADOVATE_APP_VERSION=1.0
# TRADOVATE_DEVICE_ID=bot-device-001

# ---- AWS ---------------------------------------------------
# Region donde viven los secretos en Secrets Manager y la DB en RDS
# AWS_REGION=eu-west-1
# "true" para leer credenciales de Secrets Manager; "false" usa vars TRADOVATE_* de abajo
USE_SECRETS_MANAGER=false

# ---- Logging -----------------------------------------------
# "text" para desarrollo local, "json" para AWS CloudWatch
LOG_FORMAT=text

# ---- Estrategia --------------------------------------------
# Ratio reward/risk. Ejemplo: 0.33 significa TP = 0.33 * distancia_SL
RR_RATIO=0.33

# ---- WebSocket ---------------------------------------------
# Segundos entre heartbeats al servidor de Tradovate
HEARTBEAT_INTERVAL=2.5

# ---- Persistencia ------------------------------------------
# Solo para SQLite local. En AWS define DATABASE_URL en su lugar.
DB_PATH=bot.db
# Cadena de conexion completa. Si se define, DB_PATH se ignora.
# Ejemplos:
#   SQLite local:   sqlite:///bot.db
#   PostgreSQL RDS: postgresql+psycopg2://user:pass@host:5432/dbname
# DATABASE_URL=